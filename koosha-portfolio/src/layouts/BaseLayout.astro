---
import "../styles/globals.css";
import { site } from "../data/site";

type Props = {
  title?: string;
  description?: string;
  active?: string;
};

const {
  title = site.name,
  description = site.description,
  active = "home",
} = Astro.props as Props;

const nav = [
  { href: "/", label: "Home", key: "home" },
  { href: "/projects", label: "Projects", key: "projects" },
  { href: "/about", label: "About", key: "about" },
  { href: "/resume", label: "Resume", key: "resume" },
  { href: "/contact", label: "Contact", key: "contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#efe7dc" />
    <link rel="canonical" href={site.url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label={site.name}>
          <span class="brand-mark">KP</span>
          <span>
            <strong>{site.name}</strong>
            <small>{site.handle}</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} aria-current={item.key === active ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div>
          <strong>{site.name}</strong>
          <p>{site.headline}</p>
        </div>
        <a href="mailto:koosha@kooshapari.com">koosha@kooshapari.com</a>
      </footer>
    </div>
  </body>
</html>
