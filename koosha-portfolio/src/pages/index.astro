---
import BaseLayout from "../layouts/BaseLayout.astro";
import { forwards, projectPillars, projects, profileFacts, socials, site } from "../data/site";

const featured = projects.slice(0, 4);
---

<BaseLayout title={`${site.name} — Personal portfolio`} description={site.description} active="home">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">kooshapari.com</p>
      <h1 class="display">A personal landing page for Koosha Paridehpour.</h1>
      <p class="lede">
        I build Phenotype systems, project launch surfaces, and portfolio migrations.
        This site replaces the old Adobe Portfolio shape with a cleaner home for work,
        contact, and the routes people still expect to find.
      </p>

      <div class="button-row">
        <a class="button primary" href="/projects">Browse projects</a>
        <a class="button" href="/about">About</a>
        <a class="button" href="/resume">Resume</a>
        <a class="button" href="https://github.com/KooshaPari" target="_blank" rel="noreferrer">
          GitHub
        </a>
      </div>

      <div class="fact-row">
        {profileFacts.map((fact) => (
          <div class="fact card">
            <span>{fact.label}</span>
            <strong>{fact.value}</strong>
          </div>
        ))}
      </div>
    </div>

    <div class="hero-visual card">
      <img src="/hero.jpg" alt="A warm workspace with a laptop and notebook" class="hero-image" />
      <div class="hero-overlay">
        <p class="eyebrow">Current focus</p>
        <strong>Phenotype, agent tooling, observability, and portfolio migration.</strong>
        <p>
          A clean place to route people toward current work while keeping old links alive.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">What I do</p>
        <h2>Build systems that stay usable after the launch hype fades.</h2>
      </div>
      <p>
        The work lands in platforms, agent runtimes, and the connective tissue that helps
        a project survive contact with users.
      </p>
    </div>

    <div class="grid-3">
      {projectPillars.map((pillar) => (
        <article class="card feature-card">
          <h3>{pillar.title}</h3>
          <p>{pillar.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Featured work</p>
        <h2>Selected projects</h2>
      </div>
      <a class="button" href="/projects">See all projects</a>
    </div>

    <div class="grid-2">
      {featured.map((project) => (
        <article class="card project-card">
          <div class="project-head">
            <div>
              <p class="eyebrow">{project.kind}</p>
              <h3>{project.title}</h3>
            </div>
            <span>{project.timeframe}</span>
          </div>
          <p class="project-summary">{project.summary}</p>
          <p class="project-blurb">{project.highlight}</p>
          <div class="tag-row">
            {project.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <div class="button-row">
            <a class="button primary" href={`/projects/${project.slug}`}>Open case study</a>
            {project.links.map((link) => (
              <a class="button" href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
                {link.label}
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Legacy forwards</p>
        <h2>Keep old Adobe Portfolio routes alive.</h2>
      </div>
      <p>
        These links preserve the old portfolio entry points and map them to the current
        kooshapari.com structure.
      </p>
    </div>

    <div class="card forward-card">
      <div class="forward-grid">
        {forwards.map((forward) => (
          <div class="forward-row">
            <code>{forward.source}</code>
            <span>{forward.target}</span>
            <small>{forward.note}</small>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Contact</p>
        <h2>Reach out directly.</h2>
      </div>
      <p>
        For project inquiries, collaboration, or migration work, use the links below.
      </p>
    </div>

    <div class="contact-strip card">
      {socials.map((link) => (
        <a class="contact-link" href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
          <strong>{link.label}</strong>
          <span>{link.href.replace("mailto:", "")}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(22rem, 0.95fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .hero-copy {
    padding: clamp(1.2rem, 2vw, 2rem);
    border-radius: 1.1rem;
  }

  .lede {
    max-width: 44rem;
    margin: 0.95rem 0 0;
    color: var(--muted);
    font-size: 1.05rem;
  }

  h1 {
    margin: 0.3rem 0 0;
    font-size: clamp(3.2rem, 8vw, 6.7rem);
    line-height: 0.94;
    max-width: 11ch;
  }

  .fact-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .fact {
    padding: 0.9rem 1rem;
  }

  .fact span,
  .fact strong {
    display: block;
  }

  .fact span {
    color: var(--muted);
    font-size: 0.8rem;
    margin-bottom: 0.3rem;
  }

  .fact strong {
    font-size: 0.97rem;
  }

  .hero-visual {
    overflow: hidden;
    min-height: 36rem;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.02);
  }

  .hero-overlay {
    padding: 1.2rem;
    background: linear-gradient(180deg, rgba(252, 247, 239, 0.1), rgba(252, 247, 239, 0.94));
  }

  .hero-overlay strong {
    display: block;
    font-size: 1.02rem;
    margin: 0.35rem 0 0.45rem;
  }

  .hero-overlay p {
    margin: 0;
    color: var(--muted);
  }

  .feature-card,
  .project-card,
  .contact-strip,
  .forward-card {
    padding: 1.1rem;
  }

  .feature-card h3,
  .project-card h3 {
    margin: 0.25rem 0 0;
    font-size: 1.2rem;
  }

  .feature-card p,
  .project-summary,
  .project-blurb {
    color: var(--muted);
  }

  .project-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
  }

  .project-head span {
    color: var(--muted);
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 1rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.34rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.58);
    color: var(--muted);
    font-size: 0.76rem;
  }

  .forward-grid {
    display: grid;
    gap: 0.75rem;
  }

  .forward-row {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.8rem;
    align-items: center;
    padding: 0.85rem 0;
    border-top: 1px solid var(--line);
  }

  .forward-row:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .forward-row code {
    font-size: 0.86rem;
    color: var(--accent-strong);
  }

  .forward-row span,
  .forward-row small {
    color: var(--muted);
  }

  .contact-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .contact-link {
    display: grid;
    gap: 0.2rem;
    padding: 0.95rem;
    border-radius: 0.9rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.56);
  }

  .contact-link strong {
    font-size: 0.96rem;
  }

  .contact-link span {
    color: var(--muted);
    font-size: 0.84rem;
    overflow-wrap: anywhere;
  }

  @media (max-width: 920px) {
    .hero,
    .contact-strip,
    .forward-row {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      min-height: 26rem;
    }
  }
</style>
