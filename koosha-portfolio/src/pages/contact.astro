---
import BaseLayout from "../layouts/BaseLayout.astro";
import { socials, site } from "../data/site";
---

<BaseLayout title={`Contact — ${site.name}`} description="Direct contact and social links." active="contact">
  <section class="page-hero">
    <div>
      <p class="eyebrow">Contact</p>
      <h1 class="display">Use the channel that fits the ask.</h1>
      <p class="lede">
        For collaboration, portfolio migrations, or work inquiries, email is the cleanest route.
        GitHub and LinkedIn are available if the conversation starts there.
      </p>
    </div>
    <div class="card side-panel">
      <h2>Quick path</h2>
      <a class="button primary" href="mailto:koosha@kooshapari.com">koosha@kooshapari.com</a>
    </div>
  </section>

  <section class="section">
    <div class="grid-2">
      {socials.map((link) => (
        <a class="card contact-card" href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
          <strong>{link.label}</strong>
          <span>{link.href.replace("mailto:", "")}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.7fr);
    gap: 1rem;
    align-items: start;
  }

  h1 {
    margin: 0.25rem 0 0;
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 0.95;
  }

  .lede,
  .side-panel,
  .contact-card span {
    color: var(--muted);
  }

  .side-panel,
  .contact-card {
    padding: 1.1rem;
  }

  .side-panel h2 {
    margin: 0 0 0.8rem;
    font-size: 1.05rem;
  }

  .contact-card {
    display: grid;
    gap: 0.25rem;
  }

  .contact-card strong {
    font-size: 1rem;
  }

  .contact-card span {
    overflow-wrap: anywhere;
    font-size: 0.84rem;
  }

  @media (max-width: 920px) {
    .page-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
