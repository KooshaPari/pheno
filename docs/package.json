{
  "name": "docs",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "lint": "node -e \"process.exit(0)\"",
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "docs:test:unit": "node --test tests/unit/*.test.mjs",
    "docs:test:component": "node --test tests/component/*.test.mjs",
    "docs:test:e2e": "playwright test --config tests/playwright.config.ts",
    "docs:test": "bun run docs:test:unit && bun run docs:test:component && bun run docs:test:e2e",
    "docs:check": "bun run docs:build && bun run docs:test"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "overrides": {
    "lodash-es": "^4.18.1"
  }
}
