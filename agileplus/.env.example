# Sentry Error Tracking Configuration
# Get your DSN from https://sentry.io/settings/organization/projects/

# Sentry project DSN (required for production)
# Without this, errors are logged to stderr (test mode)
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Environment identifier (defaults to "development")
# Use: development, staging, production
SENTRY_ENVIRONMENT=development

# Release version (auto-detected from Cargo.toml)
# Optional override: 0.1.0
# SENTRY_RELEASE=0.1.0

# Enable debug logging from Sentry SDK
# RUST_LOG=sentry=debug
