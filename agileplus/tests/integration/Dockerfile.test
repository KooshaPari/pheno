# Multi-stage test runner image for AgilePlus integration tests.
# Includes both Rust and Python tooling.
#
# Traceability: WP16-T095

FROM rust:1.85-bookworm AS rust-base
WORKDIR /app

# Install Python for the Python integration tests
RUN apt-get update && apt-get install -y python3 python3-pip curl git && rm -rf /var/lib/apt/lists/*

# Install uv
RUN pip3 install uv --break-system-packages

# Copy workspace files
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates/ ./crates/
COPY rust/ ./rust/
COPY tests/ ./tests/

# Build test binaries
RUN cargo build --workspace --tests 2>&1

# Copy Python sources
COPY python/ ./python/

# Install Python dependencies
RUN cd python && uv sync --all-extras

# Copy Makefile for test targets
COPY Makefile .

CMD ["make", "test-integration-inner"]
