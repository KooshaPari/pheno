#!/bin/sh
# pre-commit: Fast lint checks on staged files
set -e

# Best-effort format check (non-blocking, <5s)
mise run format --check 2>/dev/null || true

# Check staged files for trailing whitespace
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -n "$STAGED_FILES" ]; then
  TRAILING_WS=0
  for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ] && grep -qP '\s+$' "$FILE" 2>/dev/null; then
      echo "WARNING: Trailing whitespace found in: $FILE"
      TRAILING_WS=1
    fi
  done
  if [ "$TRAILING_WS" -eq 1 ]; then
    echo "ERROR: Staged files contain trailing whitespace. Please fix before committing."
    exit 1
  fi

  # Check for large files (>5MB warning)
  for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
      SIZE=$(wc -c < "$FILE" 2>/dev/null || echo 0)
      if [ "$SIZE" -gt 5242880 ]; then
        echo "WARNING: Large file detected (>5MB): $FILE (${SIZE} bytes)"
        echo "Consider using Git LFS for large files."
      fi
    fi
  done
fi

exit 0
