FROM rust:slim

RUN apt-get update && apt-get install -y \
    protobuf-compiler \
    build-essential \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY Cargo.toml Cargo.lock* ./
COPY crates/ crates/
COPY rust/ rust/
COPY proto/ proto/

RUN cargo build --workspace --release
